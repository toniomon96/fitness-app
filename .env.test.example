# Playwright E2E test environment variables
# Copy this file to .env.test and fill in the values.
# NEVER commit .env.test with real credentials.

# The URL of the running app (default: local dev server)
E2E_BASE_URL=http://localhost:3000

# A dedicated test account in your Supabase project.
# Create this account manually in the Supabase dashboard first.
# Do NOT use a real user account — tests may modify/delete data.
E2E_TEST_EMAIL=e2e-test@your-domain.com
E2E_TEST_PASSWORD=your-test-password
